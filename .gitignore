# =============================================================================
# Heroes of Might and Magic 3 ERA Plugins - Git Ignore
# Оптимизированный .gitignore для C++ плагинов
# 
# Этот файл сокращен и содержит только необходимые исключения для:
# - Visual Studio C++ проектов
# - Пользовательских настроек разработчика  
# - Результатов сборки и временных файлов
# - Специфичных для проекта файлов
#
# Удалено лишнее:
# - .NET специфичные настройки
# - Web development файлы
# - Azure, NuGet, Node.js и другие неиспользуемые технологии
# =============================================================================

# 🎮 ПОЛЬЗОВАТЕЛЬСКИЕ НАСТРОЙКИ (НЕ В GIT)
# =============================================================================
# Настройки путей и компиляции
Directory.Build.props.user
Directory.Build.targets.user
**/Directory.Build.props.user
**/Directory.Build.targets.user

# Пользовательские файлы Visual Studio проектов
*.vcxproj.user
*.vcxproj.filters.user
*.csproj.user
*.vbproj.user
*.fsproj.user

# Локальные настройки решения
*.sln.docstates
*.sln.docstates.json
*.suo
*.user
*.userosscache
launchSettings.json

# 📁 РЕЗУЛЬТАТЫ СБОРКИ
# =============================================================================
# Папки сборки
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
[Ll]og/
bld/

# Файлы сборки Visual Studio
*.ilk
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.tlog
*.lastbuildstate
*.cache
*.res
*_i.c
*_p.c
*_h.h
*.meta

# 🔧 VISUAL STUDIO ФАЙЛЫ
# =============================================================================
# Кэш и временные файлы VS
.vs/
*.rsuser
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
Generated\ Files/

# Файлы профилировщика
*.psess
*.vsp
*.vspx
*.sap

# IntelliSense
*.VisualState.xml

# 🎯 СПЕЦИФИЧНЫЕ ДЛЯ ПРОЕКТА ФАЙЛЫ
# =============================================================================
# Архивы и временные файлы проекта
*.zip
*.7z
*.map
Artifacts_AddingNewFeatures/

# Лишние solution файлы в подпапках (используем только главный H3EraPlugins.sln)

# Результаты плагинов (.era файлы в рабочих папках)
# Но НЕ исключаем их из папок релизов!
Debug/*.era
Release/*.era

# 🔍 ИНСТРУМЕНТЫ РАЗРАБОТКИ
# =============================================================================
# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
headers/H3API_for_copilot/

# 📝 ФАЙЛЫ КОТОРЫЕ ВКЛЮЧАЕМ В GIT
# =============================================================================
# Примеры пользовательских настроек
!*.vcxproj.user.example
!*.props.user.example
!Directory.Build.props.template

# Документация
!README*.md
!CONTRIBUTING.md
!VS_USER_SETTINGS.md
!QUICK_START.md

# =============================================================================
# Конец файла
# =============================================================================
